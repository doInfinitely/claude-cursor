{
  "name": "claude-cursor",
  "version": "1.0.0",
  "description": "Claude Cursor — local-first terminal session manager for Claude Code (ttyd + tmux)",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "node server/index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "NODE_ENV=production node server/index.js",
    "electron:dev": "npm run build && electron .",
    "electron:package": "npm run build && electron-forge package",
    "electron:make": "npm run build && electron-forge make"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@slack/bolt": "^4.6.0",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "concurrently": "^9.1.2",
    "electron": "^33.0.0"
  }
}
