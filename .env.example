# Server
PORT=3000
HOST=0.0.0.0

# ttyd port range (internal, not exposed externally)
TTYD_PORT_RANGE_START=7681
TTYD_PORT_RANGE_END=7780

# Needs Action detection
# ANTHROPIC_API_KEY=sk-ant-...       # Required for LLM/hybrid mode
# NEEDS_ACTION_MODE=hybrid           # regex | anthropic | hybrid (default: hybrid)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001  # Model for classification
# NEEDS_ACTION_SCAN_INTERVAL_MS=3000 # Polling interval in ms
# NEEDS_ACTION_LINES=200             # Lines to capture from tmux pane

# Discord notifications (optional)
# DISCORD_BOT_TOKEN=                 # Discord bot token (enables Discord integration)

# Slack notifications (optional — both tokens required)
# SLACK_BOT_TOKEN=xoxb-...          # Slack bot token
# SLACK_APP_TOKEN=xapp-...          # Slack app-level token for Socket Mode

# Session links in notifications
# BASE_URL=http://localhost:3000     # Public URL for session links
